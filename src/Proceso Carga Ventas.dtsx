                <component
                  refId="Package\Carga Prepago SETH\Prepago -&gt; Csv\OLE DB Source"
                  componentClassID="Microsoft.OLEDBSource"
                  contactInfo="OLE DB Source;Microsoft Corporation; Microsoft SQL Server; (C) Microsoft Corporation; All Rights Reserved; http://www.microsoft.com/sql/support;7"
                  description="OLE DB Source"
                  name="OLE DB Source"
                  usesDispositions="true"
                  version="7">
                  <properties>
                    <property
                      dataType="System.Int32"
                      description="The number of seconds before a command times out.  A value of 0 indicates an infinite time-out."
                      name="CommandTimeout">0</property>
                    <property
                      dataType="System.String"
                      description="Specifies the name of the database object used to open a rowset."
                      name="OpenRowset"></property>
                    <property
                      dataType="System.String"
                      description="Specifies the variable that contains the name of the database object used to open a rowset."
                      name="OpenRowsetVariable"></property>
                    <property
                      dataType="System.String"
                      description="The SQL command to be executed."
                      name="SqlCommand"
                      UITypeEditor="Microsoft.DataTransformationServices.Controls.ModalMultilineStringEditor, Microsoft.DataTransformationServices.Controls, Version=17.0.0.0, Culture=neutral, PublicKeyToken=89845dcd8080cc91">/**** CONSULTA DÍA HÁBIL SEMANA || FINDE ****/




DECLARE @Hoy DATE = CAST(GETDATE() AS DATE);

DECLARE @FechaConsulta DATE = DATEADD(DAY, -1, @Hoy);

DECLARE @EsDiaHabil BIT = 0;



-- Iniciamos el bucle para evaluar la fecha


WHILE @EsDiaHabil = 0

BEGIN


IF MONTH(@FechaConsulta) &lt;&gt; MONTH(@Hoy)

BEGIN
 
SET @FechaConsulta = EOMONTH(DATEADD(MONTH, -1, @Hoy));

SET @EsDiaHabil = 1; 
-- Terminamos el ciclo

END
    


-- (Sábado = 7, Domingo = 1)

ELSE 

BEGIN   

IF DATEPART(WEEKDAY, @FechaConsulta) NOT IN (7,1) 

--AND @FechaConsulta NOT IN (SELECT Fecha FROM tabla_Feriados)

BEGIN
SET @EsDiaHabil = 1;

END

ELSE

BEGIN

SET @FechaConsulta = DATEADD(DAY, -1, @FechaConsulta);
END
END
END


---- Resultado final para usar 

--SELECT @FechaConsulta AS FechaProceso;

/**** OBTENCIÓN DE VENTAS ****/

--declare @rangoFecha  date = GETDATE()
declare @rangoFecha  date = @FechaConsulta

declare @fechaDesde varchar(8) = format(DATEFROMPARTS(YEAR(@rangoFecha), MONTH(@rangoFecha), 1),'yyyyMMdd')
declare @fechaHasta varchar(8) = format((select eomonth(@rangoFecha)),'yyyyMMdd')

select 
distinct 
'' as ID_Venta_SETH
,fecha
,estado_tarjeta
,rut_ejecutivo
,sucursal
,programas
,clasificador
,colaborador
,estado_cuenta
,masivo
,impresion 
,cod_tarjeta 
,canal
,ejecutivo_activador_tarjeta
,firma_cliente
,direccion
,telefono_fijo
,telefono_celular
,email
,ejecutivo_entrega_tarjeta 
,tipo_emision
,rut
,codigo_cliente 
,segmento
,fecha_activacion
,getdate() as Fecha_ult_carga_BD
from clh.lk_stock_prepago
where flag_nueva = 1
and convert(varchar,fecha_activacion,112) between @fechaDesde and @fechaHasta
order by FECHA_ACTIVACION</property>
