          DTS:LocaleID="-1"
          DTS:ObjectName="Actualiza Subject y Body"
          DTS:ThreadHint="0">
          <DTS:Variables />
          <DTS:ObjectData>
            <SQLTask:SqlTaskData
              SQLTask:Connection="{89992C84-6E21-4FAB-A818-699FA600CD48}"
              SQLTask:BypassPrepare="False"
              SQLTask:SqlStatementSource="exec [dbo].[Etl_Actualiza_Detalle_Body]" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
          </DTS:ObjectData>
        </DTS:Executable>
        <DTS:Executable
          DTS:refId="Package\Envio Mail - Revision\Tarea Ejecutar SQL"
          DTS:CreationName="Microsoft.ExecuteSQLTask"
          DTS:Description="Tarea Ejecutar SQL"
          DTS:DTSID="{33571CE9-B1A2-4659-9D32-836B496C3CC4}"
          DTS:ExecutableType="Microsoft.ExecuteSQLTask"
          DTS:LocaleID="-1"
          DTS:ObjectName="Tarea Ejecutar SQL"
          DTS:ThreadHint="0">
          <DTS:Variables />
          <DTS:ObjectData>
            <SQLTask:SqlTaskData
              SQLTask:Connection="{89992C84-6E21-4FAB-A818-699FA600CD48}"
              SQLTask:BypassPrepare="False"
              SQLTask:SqlStatementSource="select &#xA;isnull(SMTPConnection,'') as SMTPConnection&#xA;,isnull(mailFrom,'') as mailFrom&#xA;,isnull(mailTo,'') as mailTo&#xA;,isnull(mailSubject,'') as mailSubject&#xA;,isnull(mailBody,'') as mailBody&#xA;from dbo.Etl_Mailito&#xA;where idmailito = 1"
              SQLTask:ResultType="ResultSetType_SingleRow"
              SQLTask:TypeConversionMode="None" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask">
              <SQLTask:ResultBinding
                SQLTask:ResultName="SMTPConnection"
                SQLTask:DtsVariableName="User::SMTPConnection" />
              <SQLTask:ResultBinding
                SQLTask:ResultName="mailFrom"
                SQLTask:DtsVariableName="User::mailFrom" />
              <SQLTask:ResultBinding
                SQLTask:ResultName="mailTo"
                SQLTask:DtsVariableName="User::mailTo" />
              <SQLTask:ResultBinding
                SQLTask:ResultName="mailSubject"
                SQLTask:DtsVariableName="User::mailSubject" />
              <SQLTask:ResultBinding
                SQLTask:ResultName="mailBody"
                SQLTask:DtsVariableName="User::mailBody" />
            </SQLTask:SqlTaskData>
          </DTS:ObjectData>
        </DTS:Executable>
